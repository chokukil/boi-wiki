# Intranet pilot profile.
# Copy to .env on the pilot Docker host and fill in intranet Kafka/Langflow values.
# Do not commit real hostnames, passwords, API keys, or service tokens.

DEPLOY_PROFILE=pilot-external
KAFKA_MODE=external
LANGFLOW_MODE=external

BOI_API_PORT=28000
ACTION_GATEWAY_PORT=8100
BOI_WIKI_MCP_PORT=8200

BOI_EXTERNAL_URL=https://wiki.example.internal
LANGFLOW_EXTERNAL_URL=https://langflow.example.internal
KAFKA_UI_EXTERNAL_URL=
BOI_WIKI_MCP_EXTERNAL_URL=https://wiki-mcp.example.internal
ACTION_GATEWAY_EXTERNAL_URL=

BOI_AUTH_MODE=trusted_header
SERVICE_TOKEN=replace-with-random-service-token
BOI_SESSION_SECRET=replace-with-random-session-secret
BOI_COOKIE_SECURE=true
DEFAULT_TEAM_ID=aix-tf
DEMO_EMPLOYEE_ID=100001

BOI_CONTENT_ROOT=/content/boi
BOI_CONTENT_SAFE_DIRECTORY=/content
BOI_RUNTIME_ROOT=/runtime
BOI_CONTENT_HOST_PATH=/srv/boi-wiki/content
BOI_CONTENT_MOUNT_PATH=/content
EVENTS_HOST_PATH=/srv/boi-wiki/runtime/events
ACTIONS_HOST_PATH=/srv/boi-wiki/runtime/actions
EVENTS_ROOT=/runtime/events
ACTION_LOG_ROOT=/runtime/actions
CAPABILITY_CATALOG_ROOT=/data/capability_catalog
EVENT_SKILL_CATALOG_ROOT=/data/event_skill_catalog
ACTION_SKILL_CATALOG_ROOT=/data/action_skill_catalog
BOI_AUTO_COMMIT=true
BOI_AUTO_PUSH=true
BOI_CONTENT_GIT_REMOTE=origin
BOI_CONTENT_GIT_BRANCH=main

KAFKA_BOOTSTRAP=kafka-bootstrap.example.internal:9093
KAFKA_SMOKE_BOOTSTRAP=kafka-bootstrap.example.internal:9093
BOI_EVENTS_TOPIC=boi.events
BOI_AUDIT_TOPIC=boi.audit
BOI_DLQ_TOPIC=boi.dead-letter
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SASL_USERNAME=replace-with-service-account
KAFKA_SASL_PASSWORD=replace-with-service-password
KAFKA_SSL_CAFILE=/run/secrets/kafka-ca.pem
EVENT_ROUTER_GROUP_ID=boi-event-router-pilot
EVENT_ROUTER_AUTO_OFFSET_RESET=latest
AUTO_ROUTE_EVENTS=true

LANGFLOW_URL=https://langflow-api.example.internal
LANGFLOW_SMOKE_URL=https://langflow-api.example.internal
LANGFLOW_API_KEY=replace-with-langflow-api-key
LANGFLOW_AUTH_MODE=api-key
LANGFLOW_BOI_AGENT_ENDPOINT=boi-agent
LANGFLOW_AGENT_TIMEOUT_SECONDS=180

BOI_LLM_BASE_URL=https://llm-gateway.example.internal/v1
BOI_LLM_MODEL=google/gemma-4-26b-a4b-qat
BOI_LLM_API_KEY=replace-with-llm-api-key
BOI_AGENT_BACKEND=native
BOI_AGENT_ROUTER_MODE=llm_first
BOI_AGENT_ROUTER_REQUIRED=1
BOI_AGENT_STATUS_REQUIRED=1
BOI_AGENT_SUGGESTIONS_REQUIRED=1
BOI_AGENT_COMPOSER_REQUIRED=1
BOI_AGENT_SUGGESTIONS_MAX_ATTEMPTS=3
BOI_AGENT_LLM_MAX_CONCURRENCY=1
BOI_AGENT_LLM_QUEUE_TIMEOUT_SECONDS=120
BOI_AGENT_LANGGRAPH_REQUIRED=1
BOI_AGENT_CACHE_WARMUP_ON_STARTUP=1
