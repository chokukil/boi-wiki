# Copy to .env before running. Replace secrets before intranet demo.
LANGFLOW_IMAGE=langflowai/langflow:latest
# SSO profile option: dk02315/langflow-hynix:v1.10.0-hynix-sso-rc4
LANGFLOW_PORT=7860
LANGFLOW_API_KEY=dev-langflow-key-change-me
LANGFLOW_AUTH_MODE=api-key
LANGFLOW_AUTO_LOGIN=True
LANGFLOW_SKIP_AUTH_AUTO_LOGIN=true
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=admin
LANGFLOW_SECRET_KEY=Ym9pLXdpa2ktcG9jLWRldi1zZWNyZXQta2V5LTIwMjY=

BOI_LLM_BASE_URL=http://mangugil.iptime.org:1236/v1
BOI_LLM_MODEL=google/gemma-4-26b-a4b-qat
BOI_LLM_API_KEY=not-needed

BOI_API_PORT=8000
KAFKA_EXTERNAL_PORT=9094
KAFKA_UI_PORT=8081
SERVICE_TOKEN=dev-service-token-change-me
DEFAULT_TEAM_ID=aix-tf
DEMO_EMPLOYEE_ID=100001

# BoI Wiki authentication.
# dev: local employee selector/query compatibility.
# keycloak: Keycloak OIDC browser/API auth.
# trusted_header: authenticated reverse proxy injects X-Hynix-* headers.
BOI_AUTH_MODE=dev
BOI_EXTERNAL_URL=http://localhost:8000
BOI_SESSION_SECRET=dev-boi-session-secret-change-me
BOI_COOKIE_SECURE=false
BOI_ALLOWED_EMPLOYEE_IDS=

# Keycloak / SK hynix SSO settings. Required when BOI_AUTH_MODE=keycloak.
KEYCLOAK_SERVER_URL=http://localhost:8088
KEYCLOAK_EXTERNAL_SERVER_URL=http://localhost:8088
KEYCLOAK_ISSUER_URL=http://localhost:8088
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=boi-dev
KEYCLOAK_CLIENT_ID=boi-wiki
KEYCLOAK_CLIENT_SECRET=dev-boi-wiki-client-secret
KEYCLOAK_REDIRECT_URI=http://localhost:8000/auth/callback
BOI_EMPLOYEE_CLAIM=employee_id
KEYCLOAK_EMPLOYEE_CLAIM=employee_id
BOI_TEAMS_CLAIM=groups
BOI_ROLES_CLAIM=realm_access.roles
HCP_AUTHZ_URL=
HCP_AUTHZ_CACHE_TTL_SECONDS=60
KEYCLOAK_HCP_API_URL=
KEYCLOAK_ALLOWED_EMPLOYEE=
KEYCLOAK_ADMIN_EMPLOYEES=100001

# Langflow-Hynix SSO compatibility. Used by docker-compose.sso-dev.yml.
LANGFLOW_HYNIX_BASE_IMAGE=dk02315/langflow-hynix:v1.10.0-hynix-sso-rc4
LANGFLOW_KEYCLOAK_INTERNAL_URL=http://keycloak:8080
LANGFLOW_KEYCLOAK_CLIENT_ID=langflow
LANGFLOW_KEYCLOAK_CLIENT_SECRET=dev-langflow-client-secret
LANGFLOW_KEYCLOAK_REDIRECT_URI=http://localhost:7860/api/v1/keycloak/callback
LANGFLOW_KEYCLOAK_SHARED_USERNAME=boi-langflow-shared
LANGFLOW_HCP_API_URL=http://mock-hcp:8300/v1/projects/langflow/roles
LANGFLOW_ALLOWED_EMPLOYEE=
KEYCLOAK_BUTTON_TEXT=SK hynix SSO 로그인
HCP_PROJECT_ROLES_JSON=

ACTION_GATEWAY_PORT=8100
ACTION_DRY_RUN_DEFAULT=true
ACTION_ALLOWED_HOSTS=boi-api,langflow,action-gateway,localhost,127.0.0.1,mcp-bridge,boi-wiki-mcp
MCP_BRIDGE_URL=
BOI_WIKI_MCP_PORT=8200

# Event Router dispatches Kafka events to registered connector actions through Action Gateway.
AUTO_ROUTE_EVENTS=true
