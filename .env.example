# Copy to .env before running. Replace secrets before intranet demo.
LANGFLOW_IMAGE=langflowai/langflow@sha256:3ec67ddf344b3f2393b4961aa4f87e8928798f33772fdfdc6d348bfd54f58bf0
# SSO profile option: dk02315/langflow-hynix:v1.10.0-hynix-sso-rc4
LANGFLOW_PORT=7860
LANGFLOW_API_KEY=dev-langflow-key-change-me
LANGFLOW_AUTH_MODE=api-key
LANGFLOW_BOI_AGENT_ENDPOINT=boi-agent
LANGFLOW_AGENT_TIMEOUT_SECONDS=180
LANGFLOW_AUTO_LOGIN=True
LANGFLOW_SKIP_AUTH_AUTO_LOGIN=true
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=admin
LANGFLOW_SECRET_KEY=Ym9pLXdpa2ktcG9jLWRldi1zZWNyZXQta2V5LTIwMjY=

BOI_LLM_BASE_URL=http://llm-gateway.example:1236/v1
BOI_LLM_MODEL=google/gemma-4-26b-a4b-qat
BOI_AGENT_LLM_MODEL=google/gemma-4-26b-a4b-qat
BOI_LLM_API_KEY=not-needed
BOI_AGENT_ROUTER_MODE=llm_first
BOI_AGENT_ROUTER_LLM_ENABLED=auto
BOI_AGENT_ROUTER_REQUIRED=1
BOI_AGENT_ROUTER_BASE_URL=http://llm-gateway.example:1236/v1
BOI_AGENT_ROUTER_API_KEY=boi-router-dummy-key
BOI_AGENT_ROUTER_MODEL=google/gemma-4-26b-a4b-qat
BOI_AGENT_ROUTER_TIMEOUT_SECONDS=12
BOI_AGENT_ROUTER_FAILURE_BACKOFF_SECONDS=30
BOI_AGENT_ROUTER_MAX_TOKENS=1536
BOI_AGENT_ROUTER_CONFIDENCE_THRESHOLD=0.7
BOI_AGENT_STATUS_LLM_ENABLED=auto
BOI_AGENT_STATUS_REQUIRED=1
BOI_AGENT_STATUS_BASE_URL=http://llm-gateway.example:1236/v1
BOI_AGENT_STATUS_API_KEY=boi-router-dummy-key
BOI_AGENT_STATUS_MODEL=google/gemma-4-26b-a4b-qat
BOI_AGENT_STATUS_TIMEOUT_SECONDS=12
BOI_AGENT_STATUS_MAX_TOKENS=1536
BOI_AGENT_SUGGESTIONS_LLM_ENABLED=auto
BOI_AGENT_SUGGESTIONS_REQUIRED=1
BOI_AGENT_SUGGESTIONS_BASE_URL=http://llm-gateway.example:1236/v1
BOI_AGENT_SUGGESTIONS_API_KEY=boi-router-dummy-key
BOI_AGENT_SUGGESTIONS_MODEL=google/gemma-4-26b-a4b-qat
BOI_AGENT_SUGGESTIONS_TIMEOUT_SECONDS=8
BOI_AGENT_SUGGESTIONS_MAX_TOKENS=1024
BOI_AGENT_COMPOSER_LLM_ENABLED=auto
BOI_AGENT_COMPOSER_REQUIRED=1
BOI_AGENT_COMPOSER_BASE_URL=http://llm-gateway.example:1236/v1
BOI_AGENT_COMPOSER_API_KEY=boi-router-dummy-key
BOI_AGENT_COMPOSER_MODEL=google/gemma-4-26b-a4b-qat
BOI_AGENT_COMPOSER_TIMEOUT_SECONDS=12
BOI_AGENT_COMPOSER_MAX_TOKENS=1536
BOI_AGENT_COMPOSER_MAX_ATTEMPTS=2
BOI_AGENT_BACKEND=native
BOI_AGENT_LANGGRAPH_REQUIRED=1
BOI_AGENT_NATIVE_MAX_TOOL_LOOPS=5
BOI_AGENT_NATIVE_TOOL_TIMEOUT_SECONDS=8
BOI_AGENT_CHAT_TIMEOUT_SECONDS=45
BOI_AGENT_CACHE_WARMUP_ON_STARTUP=1
BOI_BUILD_REVISION=dev

BOI_API_PORT=8000
KAFKA_EXTERNAL_PORT=9094
KAFKA_UI_PORT=8081
SERVICE_TOKEN=dev-service-token-change-me
DEFAULT_TEAM_ID=aix-tf
DEMO_EMPLOYEE_ID=100001

# BoI Wiki authentication.
# dev: local employee selector/query compatibility.
# keycloak: Keycloak OIDC browser/API auth.
# trusted_header: authenticated reverse proxy injects X-Hynix-* headers.
BOI_AUTH_MODE=dev
BOI_EXTERNAL_URL=http://localhost:8000
# User-facing external URLs. Set these for NAS/reverse-proxy deployment.
# When optional tool URLs are blank on an external request, BoI Wiki infers
# same-host NAS fallback ports from BOI_EXTERNAL_URL or the incoming Host:
# Langflow 27860, Kafka UI 28081, Action Gateway 28100, MCP Status 28200.
# Set explicit URLs when your reverse proxy or port forwarding uses different routes.
# NAS example:
# BOI_EXTERNAL_URL=http://wiki.example.internal:28000
# LANGFLOW_EXTERNAL_URL=http://wiki.example.internal:27860
# KAFKA_UI_EXTERNAL_URL=http://wiki.example.internal:28081
# BOI_WIKI_MCP_EXTERNAL_URL=http://wiki.example.internal:28200
# ACTION_GATEWAY_EXTERNAL_URL=http://wiki.example.internal:28100
LANGFLOW_EXTERNAL_URL=
KAFKA_UI_EXTERNAL_URL=
BOI_WIKI_MCP_EXTERNAL_URL=
ACTION_GATEWAY_EXTERNAL_URL=
BOI_SESSION_SECRET=dev-boi-session-secret-change-me
BOI_COOKIE_SECURE=false
BOI_ALLOWED_EMPLOYEE_IDS=

# Keycloak / SK hynix SSO settings. Required when BOI_AUTH_MODE=keycloak.
KEYCLOAK_SERVER_URL=http://localhost:8088
KEYCLOAK_EXTERNAL_SERVER_URL=http://localhost:8088
KEYCLOAK_ISSUER_URL=http://localhost:8088
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=boi-dev
KEYCLOAK_CLIENT_ID=boi-wiki
KEYCLOAK_CLIENT_SECRET=dev-boi-wiki-client-secret
KEYCLOAK_REDIRECT_URI=http://localhost:8000/auth/callback
BOI_EMPLOYEE_CLAIM=employee_id
KEYCLOAK_EMPLOYEE_CLAIM=employee_id
BOI_TEAMS_CLAIM=groups
BOI_ROLES_CLAIM=realm_access.roles
HCP_AUTHZ_URL=
HCP_AUTHZ_CACHE_TTL_SECONDS=60
KEYCLOAK_HCP_API_URL=
KEYCLOAK_ALLOWED_EMPLOYEE=
KEYCLOAK_ADMIN_EMPLOYEES=100001

# Langflow-Hynix SSO compatibility. Used by docker-compose.sso-dev.yml.
LANGFLOW_HYNIX_BASE_IMAGE=dk02315/langflow-hynix:v1.10.0-hynix-sso-rc4
LANGFLOW_KEYCLOAK_INTERNAL_URL=http://keycloak:8080
LANGFLOW_KEYCLOAK_CLIENT_ID=langflow
LANGFLOW_KEYCLOAK_CLIENT_SECRET=dev-langflow-client-secret
LANGFLOW_KEYCLOAK_REDIRECT_URI=http://localhost:7860/api/v1/keycloak/callback
LANGFLOW_KEYCLOAK_SHARED_USERNAME=boi-langflow-shared
LANGFLOW_HCP_API_URL=http://mock-hcp:8300/v1/projects/langflow/roles
LANGFLOW_ALLOWED_EMPLOYEE=
KEYCLOAK_BUTTON_TEXT=SK hynix SSO 로그인
HCP_PROJECT_ROLES_JSON=

ACTION_GATEWAY_PORT=8100
ACTION_INVOKE_TIMEOUT_SECONDS=90
ACTION_DRY_RUN_DEFAULT=true
ACTION_ALLOWED_HOSTS=boi-api,langflow,action-gateway,localhost,127.0.0.1,mcp-bridge,boi-wiki-mcp
MCP_BRIDGE_URL=
# Optional external MCP server for TimesFM forecast actions.
# Keep the real deployment URL in .env only; do not commit private hostnames.
TIMESFM_MCP_URL=
BOI_WIKI_MCP_PORT=8200
MCP_BACKEND_TIMEOUT_SECONDS=120
BOI_API_WORKERS=1

# Event Router dispatches Kafka events to registered connector actions through Action Gateway.
AUTO_ROUTE_EVENTS=true
EVENT_ROUTER_GROUP_ID=boi-event-router
EVENT_ROUTER_AUTO_OFFSET_RESET=earliest
EVENT_ROUTER_DISPATCH_TIMEOUT_SECONDS=300
EVENT_ROUTER_AUDIT_TIMEOUT_SECONDS=10
EVENT_ROUTER_ENRICH_TIMEOUT_SECONDS=60
EVENT_ROUTER_CONSUMER_SESSION_TIMEOUT_MS=60000
EVENT_ROUTER_CONSUMER_HEARTBEAT_INTERVAL_MS=10000
EVENT_ROUTER_CONSUMER_MAX_POLL_INTERVAL_MS=900000
