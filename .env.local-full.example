# Local full-stack verification profile.
# Copy to .env.local-full or .env when validating without intranet Kafka/Langflow.

DEPLOY_PROFILE=local-full
KAFKA_MODE=local
LANGFLOW_MODE=local

BOI_API_PORT=28000
ACTION_GATEWAY_PORT=8100
BOI_WIKI_MCP_PORT=8200
LANGFLOW_PORT=7860
KAFKA_EXTERNAL_PORT=9094
KAFKA_UI_PORT=8081

BOI_EXTERNAL_URL=http://localhost:28000
LANGFLOW_EXTERNAL_URL=http://localhost:7860
KAFKA_UI_EXTERNAL_URL=http://localhost:8081
BOI_WIKI_MCP_EXTERNAL_URL=http://localhost:8200
ACTION_GATEWAY_EXTERNAL_URL=http://localhost:8100

BOI_AUTH_MODE=dev
SERVICE_TOKEN=dev-service-token-change-me
DEFAULT_TEAM_ID=aix-tf
DEMO_EMPLOYEE_ID=100001

BOI_CONTENT_ROOT=/workspace/data/boi
BOI_CONTENT_SAFE_DIRECTORY=/workspace
BOI_RUNTIME_ROOT=/data
BOI_CONTENT_HOST_PATH=.
BOI_CONTENT_MOUNT_PATH=/workspace
EVENTS_HOST_PATH=./data/events
ACTIONS_HOST_PATH=./data/actions
WORKFLOW_CATALOG_ROOT=/data/workflow_catalog
EVENT_SKILL_CATALOG_ROOT=/data/event_skill_catalog
ACTION_SKILL_CATALOG_ROOT=/data/action_skill_catalog
AGENT_CATALOG_ROOT=/data/agent_catalog
BOI_AUTO_COMMIT=true
BOI_AUTO_PUSH=false
BOI_CONTENT_GIT_REMOTE=origin
BOI_CONTENT_GIT_BRANCH=

KAFKA_BOOTSTRAP=kafka:9092
KAFKA_SMOKE_BOOTSTRAP=localhost:9094
BOI_EVENTS_TOPIC=boi.events
BOI_AUDIT_TOPIC=boi.audit
BOI_DLQ_TOPIC=boi.dead-letter
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_CAFILE=
EVENT_ROUTER_AIOKAFKA_LOG_LEVEL=CRITICAL
EVENT_ROUTER_GROUP_ID=boi-event-router-local
EVENT_ROUTER_AUTO_OFFSET_RESET=earliest
EVENT_ROUTER_STARTUP_DELAY_SECONDS=5
EVENT_ROUTER_TOPIC_READY_TIMEOUT_SECONDS=60
EVENT_ROUTER_TOPIC_READY_INTERVAL_SECONDS=2
EVENT_ROUTER_POST_TOPIC_READY_DELAY_SECONDS=5
AUTO_ROUTE_EVENTS=true

LANGFLOW_URL=http://langflow:7860
LANGFLOW_SMOKE_URL=http://localhost:7860
LANGFLOW_API_KEY=dev-langflow-key-change-me
LANGFLOW_AUTH_MODE=api-key
LANGFLOW_BOI_AGENT_ENDPOINT=boi-agent
LANGFLOW_AGENT_TIMEOUT_SECONDS=180
LANGFLOW_AUTO_LOGIN=True
LANGFLOW_SKIP_AUTH_AUTO_LOGIN=true
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=admin

BOI_LLM_BASE_URL=http://llm-gateway.example:1236/v1
BOI_LLM_MODEL=google/gemma-4-26b-a4b-qat
BOI_LLM_API_KEY=not-needed
BOI_AGENT_BACKEND=native
BOI_AGENT_ROUTER_MODE=llm_first
BOI_AGENT_ROUTER_REQUIRED=1
BOI_AGENT_STATUS_REQUIRED=1
BOI_AGENT_SUGGESTIONS_REQUIRED=1
BOI_AGENT_COMPOSER_REQUIRED=1
BOI_AGENT_SUGGESTIONS_MAX_ATTEMPTS=3
BOI_AGENT_LLM_MAX_CONCURRENCY=1
BOI_AGENT_LLM_QUEUE_TIMEOUT_SECONDS=120
BOI_AGENT_LANGGRAPH_REQUIRED=1
BOI_AGENT_CACHE_WARMUP_ON_STARTUP=1
